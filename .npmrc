; NPM Configuration for Scheduling Backend
; Security and best practices

; Registry configuration
registry=https://registry.npmjs.org/

; Security settings
audit=true
audit-level=moderate

; Reduce unnecessary installs
save-exact=false
prefer-offline=false

; Trust settings
strict-ssl=true

; Update behavior  
save=true

; Engine compatibility
engine-strict=false

; Lockfile settings
package-lock=true
fund=false

; Log level
loglevel=warn
